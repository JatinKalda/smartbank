# HSBC Banking Platform - Environment Configuration Template
# Copy this file as .env and fill in your actual values

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_USER=hsbc_user
DB_PASSWORD=hsbc123
DB_NAME=hsbc_bank
DB_PORT=3306

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000
APP_SECRET=your-secret-key-here-min-32-chars-long!

# ==========================================
# EMAIL SERVICE (Choose ONE)
# ==========================================

# Option 1: Gmail SMTP
EMAIL_PROVIDER=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password  # NOT your actual Gmail password

# Option 2: Sendgrid
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3: Mailgun
# EMAIL_PROVIDER=mailgun
# MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxx
# MAILGUN_DOMAIN=sandbox-xxxx.mailgun.org

# ==========================================
# SMS SERVICE (Choose ONE)
# ==========================================

# Option 1: Twilio (RECOMMENDED)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890  # Your Twilio phone number

# Option 2: Nexmo/Vonage
# SMS_PROVIDER=nexmo
# NEXMO_API_KEY=xxxxxxxxxxxxxxxx
# NEXMO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# NEXMO_FROM=HSBC  # Sender name

# Option 3: AWS SNS
# SMS_PROVIDER=aws
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ==========================================
# PAYMENT GATEWAY (Optional)
# ==========================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=your-stripe-secret-key

# PayPal
PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# OPENAI (For AI Chatbot)
# ==========================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_FALLBACK_MODEL=gpt-4o-mini
OPENAI_VECTOR_STORE_ID=
ENABLE_OPENAI_MODERATION=false
OPENAI_MODERATION_MODEL=omni-moderation-latest
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
ENABLE_GEMINI_FALLBACK=true
AI_MAX_MESSAGE_CHARS=1000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=20

# ==========================================
# REDIS (For caching & sessions)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info
SENTRY_DSN=  # Optional: For error tracking

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=your-jwt-secret-key-min-32-chars!
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# ==========================================
# 2FA CONFIGURATION
# ==========================================
OTP_EXPIRY=600  # in seconds (10 minutes)
OTP_LENGTH=6

# ==========================================
# NOTIFICATION SETTINGS
# ==========================================
NOTIFICATION_BATCH_SIZE=100
NOTIFICATION_RETRY_ATTEMPTS=3
EMAIL_RATE_LIMIT=100  # emails per hour
SMS_RATE_LIMIT=50     # SMS per hour

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_LIVE_CHAT=false
ENABLE_PAYMENT_GATEWAY=false

# ==========================================
# DEBUG MODE
# ==========================================
DEBUG=false
LOG_SQL=false

# ==========================================
# CORS & SECURITY
# ==========================================
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your-session-secret-min-32-chars!

# ==========================================
# SMTP (Alternative Email Config)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
